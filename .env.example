# Secret used to HMAC-sign opaque endless-mode round tokens.
# Generate one with: openssl rand -hex 32
# Required by /api/round and /api/guess. Set it locally with `vercel env add HMAC_SECRET`
# (or put it in a .env.local for `vercel dev`), and add it in the Vercel dashboard for prod.
HMAC_SECRET=dev-secret-change-me

# OPTIONAL — enables the "Today worldwide" daily stats (how many people solved it
# and on which guess). Create a KV / Upstash Redis store in the Vercel dashboard
# (Storage tab) and these are injected automatically. If unset, the feature is just
# hidden — everything else works. (UPSTASH_REDIS_REST_URL/TOKEN are also accepted.)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
